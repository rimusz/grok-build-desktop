# Local build & release config (copy to .env — never commit .env)
#
#   cp .env.example .env
#
# Used by: make signed, make notarize, make dmg, make release

# Apple Developer ID Application identity (from Keychain Access or `security find-identity -v -p codesigning`)
SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# notarytool keychain profile (create once with `xcrun notarytool store-credentials`)
NOTARY_PROFILE=AC_PASSWORD

# Optional: default release type for `make release` (unsigned | notarized)
# RELEASE_TYPE=unsigned
